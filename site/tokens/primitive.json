{
  "color": {
    "neutral": {
      "0": { "$type": "color", "$value": "#ffffff" },
      "50": { "$type": "color", "$value": "#f8f7f3" },
      "100": { "$type": "color", "$value": "#efede6" },
      "200": { "$type": "color", "$value": "#ddd8c8" },
      "500": { "$type": "color", "$value": "#817b6a" },
      "700": { "$type": "color", "$value": "#3c3a32" },
      "900": { "$type": "color", "$value": "#171916" }
    },
    "moss": {
      "200": { "$type": "color", "$value": "#d7e0bd" },
      "500": { "$type": "color", "$value": "#789158" },
      "700": { "$type": "color", "$value": "#3d5536" }
    },
    "clay": {
      "200": { "$type": "color", "$value": "#e7b89a" },
      "500": { "$type": "color", "$value": "#b76f4c" }
    },
    "ink": {
      "500": { "$type": "color", "$value": "#1f2526" }
    }
  },
  "font": {
    "family": {
      "body": { "$type": "fontFamily", "$value": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" },
      "mono": { "$type": "fontFamily", "$value": "\"SFMono-Regular\", Consolas, \"Liberation Mono\", monospace" }
    }
  },
  "fontSize": {
    "body": {
      "desktop": { "$type": "dimension", "$value": "16px" },
      "mobile": { "$type": "dimension", "$value": "13px" }
    },
    "small": { "$type": "dimension", "$value": "0.875rem" },
    "h1": { "$type": "string", "$value": "clamp(2.5rem, 6vw, 5.8rem)" },
    "h2": { "$type": "string", "$value": "clamp(1.6rem, 3vw, 2.6rem)" }
  },
  "lineHeight": {
    "body": { "$type": "number", "$value": 1.55 },
    "tight": { "$type": "number", "$value": 1.05 },
    "heading": { "$type": "number", "$value": 1.12 }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "5": { "$type": "dimension", "$value": "1.5rem" },
    "6": { "$type": "dimension", "$value": "2rem" },
    "7": { "$type": "dimension", "$value": "3rem" },
    "8": { "$type": "dimension", "$value": "4rem" }
  },
  "radius": {
    "card": { "$type": "dimension", "$value": "8px" },
    "control": { "$type": "dimension", "$value": "6px" }
  },
  "shadow": {
    "card": { "$type": "shadow", "$value": "0 18px 50px rgba(31, 37, 38, 0.08)" }
  }
}
