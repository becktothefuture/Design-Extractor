{
  "color": {
    "neutral": {
      "0": { "$type": "color", "$value": "#fbfbfd" },
      "50": { "$type": "color", "$value": "#f5f5f7" },
      "100": { "$type": "color", "$value": "#ececf0" },
      "200": { "$type": "color", "$value": "rgba(29, 29, 31, 0.12)" },
      "500": { "$type": "color", "$value": "#6e6e73" },
      "700": { "$type": "color", "$value": "#424245" },
      "900": { "$type": "color", "$value": "#1d1d1f" }
    },
    "moss": {
      "200": { "$type": "color", "$value": "#e7e5e4" },
      "500": { "$type": "color", "$value": "#777169" },
      "700": { "$type": "color", "$value": "#292524" }
    },
    "clay": {
      "200": { "$type": "color", "$value": "#e7e5e4" },
      "500": { "$type": "color", "$value": "#292524" }
    },
    "ink": {
      "500": { "$type": "color", "$value": "#0c0a09" }
    }
  },
  "font": {
    "family": {
      "body": { "$type": "fontFamily", "$value": "-apple-system, BlinkMacSystemFont, \"SF Pro Text\", \"SF Pro Display\", \"Helvetica Neue\", Arial, sans-serif" },
      "mono": { "$type": "fontFamily", "$value": "\"SFMono-Regular\", Consolas, \"Liberation Mono\", monospace" }
    }
  },
  "fontSize": {
    "body": {
      "desktop": { "$type": "dimension", "$value": "16px" },
      "mobile": { "$type": "dimension", "$value": "13px" }
    },
    "small": { "$type": "dimension", "$value": "0.875rem" },
    "h1": { "$type": "string", "$value": "3.5rem" },
    "h2": { "$type": "string", "$value": "1.75rem" }
  },
  "lineHeight": {
    "body": { "$type": "number", "$value": 1.55 },
    "tight": { "$type": "number", "$value": 1.05 },
    "heading": { "$type": "number", "$value": 1.12 }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "5": { "$type": "dimension", "$value": "1.5rem" },
    "6": { "$type": "dimension", "$value": "2rem" },
    "7": { "$type": "dimension", "$value": "3rem" },
    "8": { "$type": "dimension", "$value": "4rem" }
  },
  "radius": {
    "card": { "$type": "dimension", "$value": "8px" },
    "control": { "$type": "dimension", "$value": "6px" }
  },
  "shadow": {
    "card": { "$type": "shadow", "$value": "0 1px 2px rgba(31, 37, 38, 0.05)" }
  }
