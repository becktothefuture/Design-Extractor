---
import '../styles/tokens.css';
import '../styles/starlight-map.css';
import '../styles/site.css';
import { withBase } from '../lib/paths.js';
import SearchDock from '../components/SearchDock.astro';

const { title = 'Pattern Library', description = 'A searchable library of reusable design patterns captured from real websites and images.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={withBase('/favicon.png')} type="image/png" />
    <title>{title}</title>
    <noscript><style>.site-shell{opacity:1;transform:none}.site-preloader{display:none}</style></noscript>
  </head>
  <body class="is-preloading">
    <div class="site-preloader" aria-live="polite" aria-label="Loading page">
      <span data-load-percent>0</span><span>%</span>
    </div>
    <div class="site-shell">
      <main class="site-main">
        <slot />
      </main>

      <SearchDock />
    </div>
    <script is:inline>
      // Keep the first view clean while the first preview asset loads, but never
      // block the page indefinitely. CSS also disables pointer events on the overlay.
      const loaderPercent = document.querySelector('[data-load-percent]');
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const loaderFailsafe = window.setTimeout(() => {
        document.body.classList.remove('is-preloading');
        document.body.classList.add('is-loaded');
        document.querySelector('.site-preloader')?.setAttribute('hidden', '');
      }, 3500);

      function setPercent(value) {
        if (loaderPercent) loaderPercent.textContent = String(Math.min(100, Math.max(0, Math.round(value))));
      }

      function preloadMedia(media) {
        if (media.tagName === 'IMG') {
          if (media.complete) return Promise.resolve();
          return new Promise((resolve) => {
            media.addEventListener('load', resolve, { once: true });
            media.addEventListener('error', resolve, { once: true });
          });
        }

        if (media.tagName === 'VIDEO') {
          if (media.readyState >= 2) return Promise.resolve();
          media.load();
          return new Promise((resolve) => {
            media.addEventListener('loadeddata', resolve, { once: true });
            media.addEventListener('error', resolve, { once: true });
            window.setTimeout(resolve, 2600);
          });
        }

        return Promise.resolve();
      }

      window.addEventListener('DOMContentLoaded', async () => {
        document.querySelectorAll('[data-animated-src]').forEach((media) => {
          if (prefersReducedMotion) return;
          media.setAttribute('src', media.dataset.animatedSrc);
        });
        if (prefersReducedMotion) {
          document.querySelectorAll('video[autoplay]').forEach((video) => {
            video.pause();
            video.removeAttribute('autoplay');
          });
        }

        const media = Array.from(document.querySelectorAll('[data-preload-media]'));
        let completed = 0;
        setPercent(media.length ? 8 : 100);

        await Promise.allSettled(media.map((item) => preloadMedia(item).then(() => {
          completed += 1;
          setPercent(media.length ? (completed / media.length) * 100 : 100);
        })));

        setPercent(100);
        window.setTimeout(() => {
          document.body.classList.remove('is-preloading');
          document.body.classList.add('is-loaded');
          window.clearTimeout(loaderFailsafe);
          if (prefersReducedMotion) {
            document.querySelector('.site-preloader')?.setAttribute('hidden', '');
          } else {
            window.setTimeout(() => document.querySelector('.site-preloader')?.setAttribute('hidden', ''), 650);
          }
        }, prefersReducedMotion ? 0 : 180);
      });

    </script>
  </body>
</html>
