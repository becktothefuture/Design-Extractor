---
import Layout from '../../layouts/SiteLayout.astro';
import data from '../../data/generated/knowledge.json';
import { withBase } from '../../lib/paths.js';

export function getStaticPaths() {
  return data.patterns.map((pattern) => ({
    params: { id: pattern.id },
    props: { pattern }
  }));
}

const { pattern } = Astro.props;
const mediaUrl = pattern.primaryMediaUrl ? withBase(pattern.primaryMediaUrl) : '';
const mediaType = mediaUrl.endsWith('.webm') || mediaUrl.endsWith('.mp4') ? 'video' : 'image';
const description = pattern.publicDescription || pattern.interpretation || pattern.directEvidence || pattern.summary || pattern.excerpt;
const whyItWorks = pattern.publicWhy || pattern.aestheticRole || pattern.interpretation || pattern.directEvidence;
const recipeSteps = (pattern.recipeSteps || []).length
  ? pattern.recipeSteps
  : [pattern.recipe, pattern.technicalClues].filter(Boolean);
---

<Layout title={`${pattern.title} | Pattern Library`}>
  <article class="pattern-detail">
    <a class="pattern-back" href={withBase('/')}>Back to library</a>

    <figure class="pattern-media pattern-media--lead">
      {mediaUrl && mediaType === 'video' && <video controls preload="metadata" src={mediaUrl} aria-label={`${pattern.title} captured media`}></video>}
      {mediaUrl && mediaType === 'image' && <img src={mediaUrl} alt={`${pattern.title} captured media`} loading="eager" />}
      {!mediaUrl && <div class="pattern-media__empty">No captured media available.</div>}
      <figcaption>
        <span>Captured from</span>
        {pattern.sourceUrl ? <a href={pattern.sourceUrl}>{pattern.sourceLabel}</a> : <strong>{pattern.sourceLabel}</strong>}
      </figcaption>
    </figure>

    <header class="pattern-intro">
      <h1>{pattern.title}</h1>
      <div class="pattern-tags" aria-label="Pattern tags">
        {(pattern.tags || []).map((tag) => <span>{tag}</span>)}
      </div>
      <p>{pattern.summary || pattern.excerpt}</p>
    </header>

    <section class="pattern-section" aria-labelledby="what-title">
      <h2 id="what-title">What it is</h2>
      <div class="pattern-copy">
        <p>{description}</p>
      </div>
    </section>

    <section class="pattern-section" aria-labelledby="works-title">
      <h2 id="works-title">Why it works</h2>
      <div class="pattern-copy">
        <p>{whyItWorks}</p>
      </div>
    </section>

    <section class="pattern-section" aria-labelledby="build-title">
      <h2 id="build-title">How to implement</h2>
      <div class="pattern-copy">
        {recipeSteps.length ? (
          <ol class="pattern-recipe">
            {recipeSteps.map((item) => <li>{item}</li>)}
          </ol>
        ) : (
          <p>Implementation notes have not been written for this pattern yet.</p>
        )}
        {pattern.llmPrompt && (
          <div class="pattern-action" data-copy-block>
            <div class="pattern-action__head">
              <h3>Image prompt</h3>
              <button type="button" data-copy-button>Copy</button>
            </div>
            <pre><code>{pattern.llmPrompt}</code></pre>
          </div>
        )}
        {pattern.codeRecipe && (
          <div class="pattern-action" data-copy-block>
            <div class="pattern-action__head">
              <h3>Code recipe</h3>
              <button type="button" data-copy-button>Copy</button>
            </div>
            <pre><code>{pattern.codeRecipe}</code></pre>
          </div>
        )}
      </div>
    </section>
  </article>

  <script is:inline>
    document.querySelectorAll('[data-copy-block]').forEach((block) => {
      const button = block.querySelector('[data-copy-button]');
      const code = block.querySelector('code');
      button?.addEventListener('click', async () => {
        if (!code?.textContent) return;
        try {
          await navigator.clipboard.writeText(code.textContent);
          button.textContent = 'Copied';
          window.setTimeout(() => {
            button.textContent = 'Copy';
          }, 1400);
        } catch {
          button.textContent = 'Copy failed';
          window.setTimeout(() => {
            button.textContent = 'Copy';
          }, 1400);
        }
      });
    });
  </script>
</Layout>
