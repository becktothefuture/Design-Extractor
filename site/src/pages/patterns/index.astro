---
import Layout from '../../layouts/SiteLayout.astro';
import data from '../../data/generated/knowledge.json';
import { withBase } from '../../lib/paths.js';

const patterns = data.patterns.map((pattern) => ({
  ...pattern,
  href: pattern.publicUrl || `/patterns/${pattern.id}/`,
  searchText: [
    pattern.title,
    pattern.summary,
    pattern.excerpt,
    pattern.sourceLabel,
    ...(pattern.tags || []),
    ...(pattern.appliesTo || []),
    pattern.publicDescription,
    pattern.publicWhy,
    pattern.recipe,
    ...(pattern.recipeSteps || []),
    pattern.technicalClues,
    pattern.llmPrompt,
    pattern.codeRecipe
  ].filter(Boolean).join(' ')
}));
---

<Layout title="Pattern Library">
  <section class="library-search library-search--intro library-search--compact" aria-labelledby="patterns-title">
    <div class="library-search__copy">
      <h1 id="patterns-title">All captured ideas</h1>
      <p>Search from the floating dock below, then open a pattern to reuse the idea.</p>
    </div>
  </section>

  <section class="pattern-results" aria-labelledby="results-title">
    <div class="pattern-results__head">
      <h2 id="results-title">Captured patterns</h2>
      <span data-result-count>{patterns.length} patterns</span>
    </div>

    <p class="pattern-empty" data-search-empty hidden>No matching patterns.</p>

    <div class="pattern-list">
      {patterns.map((pattern) => (
        <a class="pattern-row" href={withBase(pattern.href)} data-search-item data-search-text={pattern.searchText} data-search-tags={(pattern.tags || []).join(',')}>
          <div class="pattern-row__main">
            <h3>{pattern.title}</h3>
            <p>{pattern.summary || pattern.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
