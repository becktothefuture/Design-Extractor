---
import Layout from '../../layouts/SiteLayout.astro';
import data from '../../data/generated/knowledge.json';
import { withBase } from '../../lib/paths.js';
---

<Layout title="Moments | Design Extractor">
  <h1 class="page-title">Moments</h1>
  <p class="page-intro">Moments are recorded proof boundaries: short media captures showing what was actually observed.</p>

  <section class="section">
    <div class="media-grid">
      {data.moments.map((moment) => (
        <article class="media-card">
          {moment.mediaPath?.endsWith('.webm') ? (
            <video controls preload="metadata" src={withBase(moment.publicMediaPath)}></video>
          ) : (
            <img src={withBase(moment.publicMediaPath)} alt="" loading="lazy" />
          )}
          <h3>{moment.title}</h3>
          <p>{moment.extractId} · {moment.category}</p>
        </article>
      ))}
    </div>
  </section>
</Layout>
