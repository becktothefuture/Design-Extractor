---
import Layout from '../../layouts/SiteLayout.astro';
import data from '../../data/generated/knowledge.json';
---

<Layout title="Categories | Design Extractor">
  <h1 class="page-title">Categories</h1>
  <p class="page-intro">Categories group findings and patterns by design concern: motion, hover, responsiveness, layout, media, and more.</p>

  <section class="section">
    <div class="card-grid">
      {data.categories.map((category) => (
        <div class="library-card">
          <div class="library-card__meta">
            <span class="pill">{category.count} nodes</span>
          </div>
          <h3>{category.name}</h3>
          <p>{category.nodes.slice(0, 4).map((node) => node.title).join(', ')}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
