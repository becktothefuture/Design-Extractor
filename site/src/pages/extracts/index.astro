---
import Layout from '../../layouts/SiteLayout.astro';
import data from '../../data/generated/knowledge.json';
const withBase = (href) => `${import.meta.env.BASE_URL}${href.replace(/^\//, '')}`;
---

<Layout title="Extracts | Design Extractor">
  <h1 class="page-title">Extracts</h1>
  <p class="page-intro">Raw extraction reports are the evidence layer behind the library. Each one links source observations, captured moments, reusable findings, and confidence limits.</p>

  <section class="section">
    <div class="list-stack">
      {data.extracts.map((extract) => (
        <a class="list-row" href={withBase(extract.docUrl)}>
          <div>
            <h3>{extract.title}</h3>
            <p>{extract.summary}</p>
          </div>
          <div class="pill-row">
            <span class="pill">{extract.sourceType}</span>
            <span class="pill">{extract.date}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
