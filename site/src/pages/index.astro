---
import Layout from '../layouts/SiteLayout.astro';
import data from '../data/generated/knowledge.json';
import { withBase } from '../lib/paths.js';

const patterns = data.patterns.map((pattern) => ({
  ...pattern,
  href: pattern.publicUrl || `/patterns/${pattern.id}/`,
  searchText: [
    pattern.title,
    pattern.summary,
    pattern.excerpt,
    pattern.sourceLabel,
    ...(pattern.tags || []),
    ...(pattern.appliesTo || []),
    pattern.recipe,
    pattern.technicalClues
  ].filter(Boolean).join(' ')
}));
---

<Layout title="Design Patterns Library">
  <section class="library-search" aria-labelledby="library-title">
    <div class="library-search__copy">
      <h1 id="library-title">Design patterns captured from the web.</h1>
      <p>Search by keyword or tag. Open a pattern to see the captured moment, source, plain-language use case, and implementation notes.</p>
    </div>
    <label class="pattern-search">
      <span>Search patterns</span>
      <input id="pattern-search" type="search" placeholder="scroll, hover, cards, photography..." autocomplete="off" />
    </label>
  </section>

  <section class="pattern-results" aria-labelledby="results-title">
    <div class="pattern-results__head">
      <h2 id="results-title">Captured patterns</h2>
      <span data-result-count>{patterns.length} patterns</span>
    </div>

    <p class="pattern-empty" data-search-empty hidden>No matching patterns.</p>

    <div class="pattern-list">
      {patterns.map((pattern) => (
        <a class="pattern-row" href={withBase(pattern.href)} data-search-item data-search-text={pattern.searchText}>
          <div class="pattern-row__main">
            <h3>{pattern.title}</h3>
            <p>{pattern.summary || pattern.excerpt}</p>
          </div>
          <div class="pattern-row__meta">
            <span>{pattern.sourceLabel}</span>
            <ul aria-label={`Tags for ${pattern.title}`}>
              {(pattern.tags || []).map((tag) => <li>{tag}</li>)}
            </ul>
          </div>
        </a>
      ))}
    </div>
  </section>

  <script is:inline>
    const searchInput = document.querySelector('#pattern-search');
    const rows = Array.from(document.querySelectorAll('[data-search-item]'));
    const empty = document.querySelector('[data-search-empty]');
    const count = document.querySelector('[data-result-count]');

    function applySearch() {
      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      rows.forEach((row) => {
        const match = !query || row.dataset.searchText.toLowerCase().includes(query);
        row.classList.toggle('is-hidden', !match);
        if (match) visibleCount += 1;
      });

      empty.hidden = visibleCount > 0;
      count.textContent = `${visibleCount} ${visibleCount === 1 ? 'pattern' : 'patterns'}`;
    }

    searchInput?.addEventListener('input', applySearch);
  </script>
</Layout>
