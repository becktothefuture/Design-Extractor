---
import Layout from '../layouts/SiteLayout.astro';
import data from '../data/generated/knowledge.json';
import { withBase } from '../lib/paths.js';

const sections = [
  { title: 'Patterns', count: data.patterns.length, href: '/patterns/', note: 'Reusable moves you can put into a brief or build ticket.' },
  { title: 'Extracts', count: data.extracts.length, href: '/extracts/', note: 'Source-backed reports with evidence, limits, and implementation notes.' },
  { title: 'Moments', count: data.moments.length, href: '/moments/', note: 'GIF and video proof for motion, hover, scroll, and media behavior.' },
  { title: 'Recipes', count: data.recipes.length || data.patterns.length, href: '/recipes/', note: 'Build-ready guidance pulled from the pattern library.' },
];

const latestExtracts = data.extracts.slice(0, 4);
const searchablePatterns = data.patterns.map((item) => ({
  ...item,
  type: 'Pattern',
  href: item.docUrl,
  text: `${item.title} ${item.category} ${item.excerpt} ${item.confidence}`
}));
const searchableExtracts = data.extracts.map((item) => ({
  ...item,
  type: 'Extract',
  href: item.docUrl,
  text: `${item.title} ${item.sourceType} ${item.summary} ${item.goal} ${item.confidence}`
}));
---

<Layout title="Design Extractor Library">
  <div class="home-layout">
    <main class="home-content">
      <section class="home-intro" aria-labelledby="home-title">
        <h1 id="home-title">Design Extractor</h1>
        <p>Reusable design patterns captured from real websites, images, and interactions.</p>
      </section>

      <section class="home-link-grid" aria-label="Primary library sections">
        {sections.map((section) => (
          <a class="home-link" href={withBase(section.href)}>
            <strong>{section.title}</strong>
            <span>{section.count}</span>
            <p>{section.note}</p>
          </a>
        ))}
      </section>

      <p class="home-empty" data-search-empty hidden>No matching items.</p>

      <section class="home-section" aria-labelledby="patterns-title" data-search-section>
        <div class="home-section__head">
          <h2 id="patterns-title">Patterns</h2>
          <a href={withBase('/patterns/')}>All patterns</a>
        </div>
        <div class="home-list">
          {searchablePatterns.map((item) => (
            <a class="home-row" href={withBase(item.href)} data-search-item data-search-text={item.text}>
              <span class="home-row__type">{item.type}</span>
              <strong>{item.title}</strong>
              <p>{item.excerpt}</p>
              <span class="home-row__meta">{item.category} · {item.confidence}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="home-section" aria-labelledby="extracts-title" data-search-section>
        <div class="home-section__head">
          <h2 id="extracts-title">Extracts</h2>
          <a href={withBase('/extracts/')}>All extracts</a>
        </div>
        <div class="home-list">
          {searchableExtracts.map((item) => (
            <a class="home-row" href={withBase(item.href)} data-search-item data-search-text={item.text}>
              <span class="home-row__type">{item.type}</span>
              <strong>{item.title}</strong>
              <p>{item.summary}</p>
              <span class="home-row__meta">{item.sourceType} · {item.confidence}</span>
            </a>
          ))}
        </div>
      </section>
    </main>

    <aside class="home-sidebar" aria-label="Library controls">
      <label class="home-search">
        <span>Search library</span>
        <input id="home-search" type="search" placeholder="Hover, scroll, photography..." autocomplete="off" />
      </label>

      <nav class="home-side-block" aria-label="Browse">
        <h2>Browse</h2>
        {sections.map((section) => (
          <a href={withBase(section.href)}>
            <span>{section.title}</span>
            <strong>{section.count}</strong>
          </a>
        ))}
        <a href={withBase('/generated/')}>
          <span>Generated docs</span>
          <strong>{data.nodes.length}</strong>
        </a>
      </nav>

      <section class="home-side-block" aria-labelledby="latest-title">
        <h2 id="latest-title">Latest Captures</h2>
        {latestExtracts.map((extract) => (
          <a href={withBase(extract.docUrl)}>
            <span>{extract.title}</span>
            <small>{extract.date || 'Undated'}</small>
          </a>
        ))}
      </section>

      <section class="home-side-block home-stats" aria-label="Library counts">
        <h2>Status</h2>
        <dl>
          <div><dt>Findings</dt><dd>{data.findings.length}</dd></div>
          <div><dt>Moments</dt><dd>{data.moments.length}</dd></div>
          <div><dt>Categories</dt><dd>{data.categories.length}</dd></div>
        </dl>
      </section>
    </aside>
  </div>

  <script is:inline>
    const searchInput = document.querySelector('#home-search');
    const rows = Array.from(document.querySelectorAll('[data-search-item]'));
    const sections = Array.from(document.querySelectorAll('[data-search-section]'));
    const empty = document.querySelector('[data-search-empty]');

    function applySearch() {
      const query = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      rows.forEach((row) => {
        const match = !query || row.dataset.searchText.toLowerCase().includes(query);
        row.classList.toggle('is-hidden', !match);
        if (match) visibleCount += 1;
      });

      sections.forEach((section) => {
        const sectionHasMatch = Array.from(section.querySelectorAll('[data-search-item]')).some((row) => !row.classList.contains('is-hidden'));
        section.classList.toggle('is-hidden', !sectionHasMatch);
      });

      empty.hidden = visibleCount > 0;
    }

    searchInput?.addEventListener('input', applySearch);
  </script>
</Layout>
