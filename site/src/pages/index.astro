---
import Layout from '../layouts/SiteLayout.astro';
import data from '../data/generated/knowledge.json';
import { withBase } from '../lib/paths.js';

const patterns = data.patterns.map((pattern) => ({
  ...pattern,
  href: pattern.publicUrl || `/patterns/${pattern.id}/`,
  date: pattern.updatedAt || pattern.createdAt || '',
  // Search is intentionally broad: designers can type a feeling, source, tag,
  // or implementation clue and still land on the relevant pattern.
  searchText: [
    pattern.title,
    pattern.summary,
    pattern.excerpt,
    pattern.sourceLabel,
    ...(pattern.tags || []),
    ...(pattern.appliesTo || []),
    pattern.publicDescription,
    pattern.publicWhy,
    pattern.recipe,
    ...(pattern.recipeSteps || []),
    pattern.technicalClues,
    pattern.llmPrompt,
    pattern.codeRecipe
  ].filter(Boolean).join(' ')
})).sort((a, b) => String(b.date).localeCompare(String(a.date)) || String(a.title).localeCompare(String(b.title)));

const listedPatterns = patterns;
const latestPatterns = patterns.slice(0, 4);
const tagCounts = new Map();
patterns.forEach((pattern) => {
  (pattern.tags || []).forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const tags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 12);

function mediaUrl(pattern) {
  return withBase(pattern.previewMediaUrl || pattern.primaryMediaUrl || `/${pattern.previewMedia || pattern.primaryMedia || ''}`);
}

function posterUrl(pattern) {
  return withBase(pattern.previewPosterUrl || pattern.previewMediaUrl || pattern.primaryMediaUrl || `/${pattern.previewPoster || pattern.previewMedia || pattern.primaryMedia || ''}`);
}

function isVideo(pattern) {
  return /\.(webm|mp4|mov)$/i.test(pattern.previewMedia || pattern.previewMediaUrl || pattern.primaryMedia || pattern.primaryMediaUrl || '');
}

function isAnimatedImage(pattern) {
  return /\.(gif)$/i.test(pattern.previewMedia || pattern.previewMediaUrl || pattern.primaryMedia || pattern.primaryMediaUrl || '');
}
---

<Layout title="Beck's Pattern Library">
  <section class="library-home" aria-labelledby="library-title">
    <div class="library-home__search">
      <h1 id="library-title">Beck's Pattern Library</h1>
      <p class="library-home__intro">Captured web details, interaction ideas, and visual moves worth reusing.</p>
      <div class="library-home__meta" aria-label="Library summary">
        <span>{patterns.length} patterns</span>
        <span>{tags.length} tags</span>
        {latestPatterns[0]?.title && <span>Latest: {latestPatterns[0].title}</span>}
      </div>
    </div>
  </section>

  <section class="latest-patterns" aria-labelledby="latest-title">
    <div class="pattern-results__head">
      <h2 id="latest-title">Latest patterns recorded</h2>
      <span data-result-count aria-live="polite">{patterns.length} patterns</span>
    </div>

    <p class="pattern-empty" data-search-empty hidden>No matching patterns.</p>

    <div class="preview-grid">
      {listedPatterns.map((pattern, index) => (
        <a class="preview-card" href={withBase(pattern.href)} data-search-item data-search-text={pattern.searchText} data-search-tags={(pattern.tags || []).join(',')}>
          <figure>
            {isVideo(pattern) ? (
              <video src={mediaUrl(pattern)} autoplay muted loop playsinline preload="metadata" poster={posterUrl(pattern)} data-preload-media={index === 0 ? 'true' : undefined}></video>
            ) : isAnimatedImage(pattern) ? (
              <img src={posterUrl(pattern)} data-animated-src={mediaUrl(pattern)} data-static-src={posterUrl(pattern)} alt={`${pattern.title} preview`} loading="eager" decoding="async" data-preload-media={index === 0 ? 'true' : undefined} />
            ) : (
              <img src={posterUrl(pattern)} alt={`${pattern.title} preview`} loading="eager" decoding="async" data-preload-media={index === 0 ? 'true' : undefined} />
            )}
          </figure>
          <div class="preview-card__body">
            <h3>{pattern.title}</h3>
            <p>{pattern.summary || pattern.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
