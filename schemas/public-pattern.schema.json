{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Public Design Pattern",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "status",
    "source_label",
    "capture_status",
    "primary_media",
    "summary",
    "tags"
  ],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["pattern"]
    },
    "status": {
      "type": "string",
      "enum": ["provisional", "active", "superseded", "merged", "rejected"]
    },
    "source_url": { "type": "string" },
    "source_label": { "type": "string" },
    "capture_status": {
      "type": "string",
      "enum": ["verified", "captured", "partial", "needs-recapture"]
    },
    "primary_media": {
      "type": "string",
      "pattern": "^media/.+\\.(gif|webm|png|jpe?g)$"
    },
    "summary": { "type": "string" },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "type": "string" },
      "uniqueItems": true
    }
  },
  "additionalProperties": true
}
