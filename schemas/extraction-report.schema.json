{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/design-extractor-brain/extraction-report.schema.json",
  "title": "Extraction Report",
  "type": "object",
  "required": [
    "extract_id",
    "source",
    "source_type",
    "goal",
    "created_at",
    "limits",
    "evidence",
    "moments",
    "interaction_decomposition",
    "findings",
    "recipes",
    "reuse_readiness",
    "knowledge_nodes",
    "open_questions"
  ],
  "properties": {
    "extract_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "source": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": ["website", "image", "text", "mixed"]
    },
    "goal": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "limits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "method",
          "source_ref",
          "capture_context",
          "captured_at",
          "media_path",
          "observation",
          "what_it_proves",
          "what_it_does_not_prove",
          "confidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "method": {
            "type": "string",
            "enum": [
              "browser-observed",
              "screenshot-observed",
              "recording-observed",
              "dom-derived",
              "css-derived",
              "js-derived",
              "network-derived",
              "text-derived",
              "visual-estimated",
              "inferred"
            ]
          },
          "source_ref": {
            "type": "string"
          },
          "capture_context": {
            "type": "string"
          },
          "captured_at": {
            "type": "string",
            "format": "date"
          },
          "media_path": {
            "type": "string",
            "description": "Relative media path, or 'not available' when no media supports this evidence item."
          },
          "observation": {
            "type": "string"
          },
          "what_it_proves": {
            "type": "string"
          },
          "what_it_does_not_prove": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        },
        "additionalProperties": false
      }
    },
    "moments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "media_path",
          "viewport",
          "device_class",
          "capture_tool",
          "timing_basis",
          "duration",
          "what_it_proves",
          "what_it_does_not_prove",
          "confidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "media_path": {
            "type": "string"
          },
          "viewport": {
            "type": "string"
          },
          "device_class": {
            "type": "string",
            "enum": ["desktop", "tablet", "mobile", "unknown"]
          },
          "capture_tool": {
            "type": "string"
          },
          "timing_basis": {
            "type": "string",
            "enum": ["measured", "estimated", "unknown"]
          },
          "duration": {
            "type": "string"
          },
          "what_it_proves": {
            "type": "string"
          },
          "what_it_does_not_prove": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        },
        "additionalProperties": false
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "interaction_decomposition": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "interaction",
          "trigger",
          "user_intent",
          "pre_state",
          "feedback",
          "transition",
          "settled_state",
          "edge_states",
          "feel",
          "evidence_refs",
          "confidence"
        ],
        "properties": {
          "interaction": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "user_intent": {
            "type": "string"
          },
          "pre_state": {
            "type": "string"
          },
          "feedback": {
            "type": "string"
          },
          "transition": {
            "type": "string"
          },
          "settled_state": {
            "type": "string"
          },
          "edge_states": {
            "type": "string"
          },
          "feel": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        },
        "additionalProperties": false
      }
    },
    "recipes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reuse_readiness": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["recipe_id", "status", "recreate_without_source", "blocker"],
        "properties": {
          "recipe_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "needs-work", "blocked"]
          },
          "recreate_without_source": {
            "type": "string",
            "enum": ["yes", "partial", "no"]
          },
          "blocker": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "knowledge_nodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
